{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Qorix",
  "version": "0.24.0",
  "identifier": "dev.qorix.app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Qorix",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "transparent": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ansxuman/QoriX/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERBM0M5NUI5N0RENTExQ0YKUldUUEVkVjl1WlU4MnR0cXhrMHNtQVF1K3ZHMk9UVmQ3MHU0UWd0L2FWRTBFL0VyZWJnMlA2WVYK"
    },
    "deep-link": {
      "desktop": {
        "schemes": ["qorix"]
      }
    }
  }
}
